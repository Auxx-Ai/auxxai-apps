        "type": "@shopify:shopify",
        "appSlug": "shopify",
        "blockId": "shopify",
        "title": "Shopify: Create Metafield",
        "desc": "Store a custom color hex on a product",
        "resource": "metafield",
        "operation": "create",
        "ownerResource": "product",
        "ownerId": "{{product-node.product.productId}}",
        "createNamespace": "custom",
