{
  "$schema": "Shopify App — Metafield Resource: Node data examples for all operations",
  "$notes": [
    "fieldModes convention (source: isVariableMode = fieldModes[field] !== true):",
    "  true  = constant/literal mode — value is used as-is",
    "  false = variable mode — {{nodeId.field}} references are resolved",
    "  absent = variable mode (same as false)",
    "'ownerResource' and 'ownerId' are SHARED fields used across all metafield operations",
    "'ownerId' is not required when ownerResource is 'shop'",
    "Output for create/get/update: metafield.{ metafieldId, namespace, key, value, type, ownerResource, ownerId, createdAt, updatedAt }",
    "Output for getMany: metafields[].{ same fields }, count",
    "Output for delete: success"
  ],
