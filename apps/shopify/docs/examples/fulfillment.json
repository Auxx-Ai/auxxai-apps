        "type": "@shopify:shopify",
        "appSlug": "shopify",
        "blockId": "shopify",
        "title": "Shopify: Create Fulfillment",
        "desc": "Fulfill all items on an order with tracking info",
        "resource": "fulfillment",
        "operation": "create",
        "orderId": "{{order-node.order.orderId}}",
        "createLocationId": "",
        "createTrackingNumber": "1Z9999999999999999",
        "createTrackingCompany": "UPS",
