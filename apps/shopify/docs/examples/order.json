{
  "$schema": "Shopify App — Order Resource: Node data examples for all operations",
  "$notes": [
    "fieldModes convention (source: isVariableMode = fieldModes[field] !== true):",
    "  true  = constant/literal mode — value is used as-is",
    "  false = variable mode — {{nodeId.field}} references are resolved",
    "  absent = variable mode (same as false)",
    "Only set fieldModes[field] = true for fields you want treated as literal strings.",
    "createLineItems is required for order.create — must include at least one item",
    "currency fields (price, totalPrice, etc.) are in cents (e.g. 1999 = $19.99)",
    "Output for create/get/update: order.{ orderId, orderNumber, name, email, totalPrice, subtotalPrice, currency, financialStatus, fulfillmentStatus, tags, note, lineItems, customer, createdAt, updatedAt, orderStatusUrl }",
    "Output for getMany: orders[].{ same fields }, count",
    "Output for delete: success"
  ],
  "examples": [
    {
      "$operation": "order.create",
      "id": "shopify-order-create-001",
      "type": "standard",
      "position": { "x": 0, "y": 0 },
      "data": {
        "id": "shopify-order-create-001",
        "type": "@shopify:shopify",
        "appSlug": "shopify",
        "blockId": "shopify",
        "title": "Shopify: Create Order",
        "desc": "Create a new order in Shopify",
        "resource": "order",
        "operation": "create",
        "createLineItems": [
          {
            "productId": "{{product-node.product.productId}}",
            "variantId": "{{variant-node.variant.variantId}}",
            "title": "Classic T-Shirt",
            "quantity": 1,
            "price": 2999
          }
        ],
        "createEmail": "{{customer-node.customer.email}}",
        "createFulfillmentStatus": "",
        "createNote": "Submitted via support workflow",
        "createTags": "support,auto-created",
        "createSendReceipt": false,
        "createSendFulfillmentReceipt": false,
        "createInventoryBehaviour": "bypass",
        "createLocationId": "",
        "createSourceName": "web",
        "createTest": false,
        "createShippingFirstName": "{{customer-node.customer.firstName}}",
        "createShippingLastName": "{{customer-node.customer.lastName}}",
        "createShippingAddress1": "123 Main St",
        "createShippingAddress2": "",
        "createShippingCity": "New York",
        "createShippingProvince": "NY",
        "createShippingCountry": "US",
        "createShippingZip": "10001",
        "createShippingPhone": "",
        "createBillingFirstName": "",
        "createBillingLastName": "",
        "createBillingAddress1": "",
        "createBillingAddress2": "",
        "createBillingCity": "",
        "createBillingProvince": "",
        "createBillingCountry": "",
        "createBillingZip": "",
        "createBillingPhone": "",
        "createDiscountCodes": [],
        "fieldModes": {
          "createNote": true,
          "createTags": true,
          "createSourceName": true,
          "createShippingAddress1": true,
          "createShippingCity": true,
          "createShippingProvince": true,
          "createShippingCountry": true,
          "createShippingZip": true
        },
        "_connectedSourceHandleIds": ["source"],
        "_connectedTargetHandleIds": ["target"]
      },
      "width": 244,
      "height": 100
    },
    {
      "$operation": "order.get",
      "id": "shopify-order-get-001",
      "type": "standard",
      "position": { "x": 0, "y": 0 },
      "data": {
        "id": "shopify-order-get-001",
        "type": "@shopify:shopify",
        "appSlug": "shopify",
        "blockId": "shopify",
        "title": "Shopify: Get Order",
        "desc": "Fetch a single order by ID",
        "resource": "order",
        "operation": "get",
        "getOrderId": "{{some-node.order.orderId}}",
        "getFields": [],
        "fieldModes": {},
        "_connectedSourceHandleIds": ["source"],
        "_connectedTargetHandleIds": ["target"]
      },
      "width": 244,
      "height": 100
    },
    {
      "$operation": "order.getMany",
      "id": "shopify-order-get-many-001",
      "type": "standard",
      "position": { "x": 0, "y": 0 },
      "data": {
        "id": "shopify-order-get-many-001",
        "type": "@shopify:shopify",
        "appSlug": "shopify",
        "blockId": "shopify",
        "title": "Shopify: Get Orders",
        "desc": "Fetch multiple orders with optional filters",
        "resource": "order",
        "operation": "getMany",
        "getManyStatus": "open",
