    {
      "$operation": "order.delete",
      "id": "shopify-order-delete-001",
      "type": "standard",
      "position": { "x": 0, "y": 0 },
      "data": {
        "id": "shopify-order-delete-001",
        "type": "@shopify:shopify",
        "appSlug": "shopify",
        "blockId": "shopify",
        "title": "Shopify: Delete Order",
        "desc": "Delete an order from Shopify",
        "resource": "order",
        "operation": "delete",
        "deleteOrderId": "{{some-node.order.orderId}}",
        "fieldModes": {},
        "_connectedSourceHandleIds": ["source"],
        "_connectedTargetHandleIds": ["target"]
      },
      "width": 244,
      "height": 100
    }
  ],
  "outputs": {
    "create_get_update": {
      "order": {
        "orderId": "string — Shopify numeric ID",
        "orderNumber": "string — e.g. '#1001'",
        "name": "string — e.g. '#1001 - Jane Doe'",
        "email": "email",
        "totalPrice": "currency (cents)",
        "subtotalPrice": "currency (cents)",
        "currency": "string — e.g. 'USD'",
        "financialStatus": "string — e.g. 'paid', 'pending', 'refunded'",
        "fulfillmentStatus": "string — e.g. 'fulfilled', 'partial', '' (unfulfilled)",
        "tags": "string — comma-separated",
        "note": "string",
        "lineItems": "string (JSON array)",
        "customer": "string (JSON object)",
        "createdAt": "datetime (ISO 8601)",
        "updatedAt": "datetime (ISO 8601)",
        "orderStatusUrl": "url"
      }
    },
    "getMany": {
      "orders": "array of order objects (same fields as above)",
      "count": "number (integer)"
    },
    "delete": {
      "success": "boolean"
    }
  },
  "fieldEnums": {
    "createFulfillmentStatus": ["'' (unfulfilled)", "fulfilled", "partial", "restocked"],
    "createInventoryBehaviour": ["bypass", "decrement_ignoring_policy", "decrement_obeying_policy"],
    "getManyStatus": ["any", "open", "closed", "cancelled"],
    "getManyFinancialStatus": ["any", "authorized", "paid", "partially_paid", "partially_refunded", "pending", "refunded", "unpaid", "voided"],
    "getManyFulfillmentStatus": ["any", "partial", "shipped", "unfulfilled", "unshipped"],
    "getManyLimit": ["10", "25", "50", "100", "250"]
  }
}
