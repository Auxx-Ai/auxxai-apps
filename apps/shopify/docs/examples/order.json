        "resource": "order",
        "operation": "update",
        "updateOrderId": "{{some-node.order.orderId}}",
        "updateEmail": "",
        "updateNote": "Support ticket resolved",
        "updateTags": "resolved,support",
        "updateSourceName": "",
        "updateLocationId": "",
        "updateShippingFirstName": "",
        "updateShippingLastName": "",
        "updateShippingAddress1": "",
        "updateShippingAddress2": "",
