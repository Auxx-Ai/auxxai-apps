        "createInventoryQuantity": 100,
        "createInventoryPolicy": "deny",
        "createFulfillmentService": "manual",
        "createRequiresShipping": true,
        "createTaxable": true,
        "createOption1": "Small",
        "createOption2": "Red",
        "createOption3": "",
        "fieldModes": {
          "createTitle": true,
          "createSku": true,
          "createWeightUnit": true,
          "createInventoryPolicy": true,
          "createFulfillmentService": true,
          "createOption1": true,
          "createOption2": true
        },
        "_connectedSourceHandleIds": ["source"],
        "_connectedTargetHandleIds": ["target"]
      },
      "width": 244,
      "height": 100
    },
    {
