  "outputs": {
    "create_get_update": {
      "variant": {
        "variantId": "string — Shopify numeric ID",
        "title": "string — e.g. 'Small / Red'",
        "price": "currency (cents)",
        "compareAtPrice": "currency (cents)",
        "sku": "string",
        "barcode": "string",
        "weight": "number",
        "weightUnit": "string — 'g', 'kg', 'oz', 'lb'",
        "inventoryItemId": "string — Shopify inventory item ID",
        "inventoryQuantity": "number (integer)",
        "option1": "string",
        "option2": "string",
        "option3": "string",
        "createdAt": "datetime (ISO 8601)",
        "updatedAt": "datetime (ISO 8601)"
      }
    },
    "getMany": {
      "variants": "array of variant objects (same fields as above)",
      "count": "number (integer)"
    },
    "delete": {
      "success": "boolean"
    }
  },
  "fieldEnums": {
    "createWeightUnit": ["g", "kg", "oz", "lb"],
    "createInventoryPolicy": ["deny", "continue"],
    "updateWeightUnit": ["'' (no change)", "g", "kg", "oz", "lb"],
