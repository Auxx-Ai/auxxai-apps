{
  "$schema": "Shopify App — Product Variant Resource: Node data examples for all operations",
  "$notes": [
    "fieldModes convention (source: isVariableMode = fieldModes[field] !== true):",
    "  true  = constant/literal mode — value is used as-is",
    "  false = variable mode — {{nodeId.field}} references are resolved",
    "  absent = variable mode (same as false)",
    "'productId' is a SHARED required field across ALL variant operations — always include it",
    "currency fields (price, compareAtPrice) are in cents (e.g. 1999 = $19.99)",
    "Output for create/get/update: variant.{ variantId, title, price, compareAtPrice, sku, barcode, weight, weightUnit, inventoryItemId, inventoryQuantity, option1, option2, option3, createdAt, updatedAt }",
    "Output for getMany: variants[].{ same fields }, count",
    "Output for delete: success"
  ],
  "examples": [
    {
      "$operation": "variant.create",
      "id": "shopify-variant-create-001",
      "type": "standard",
      "position": { "x": 0, "y": 0 },
      "data": {
        "id": "shopify-variant-create-001",
        "type": "@shopify:shopify",
        "appSlug": "shopify",
        "blockId": "shopify",
        "title": "Shopify: Create Variant",
        "desc": "Create a new product variant",
        "resource": "variant",
        "operation": "create",
        "productId": "{{product-node.product.productId}}",
        "createTitle": "Small / Red",
        "createPrice": 2999,
