        "_connectedTargetHandleIds": ["target"]
      },
      "width": 244,
      "height": 100
    }
  ],
  "outputs": {
    "create_get_update_complete": {
      "draftOrder": {
        "draftOrderId": "string — Shopify numeric ID",
        "name": "string — e.g. '#D1'",
        "status": "string — 'open', 'invoice_sent', 'completed'",
        "email": "email",
        "totalPrice": "currency (cents)",
        "subtotalPrice": "currency (cents)",
        "currency": "string",
        "tags": "string — comma-separated",
        "note": "string",
        "lineItems": "string (JSON array)",
        "customer": "string (JSON object)",
        "orderId": "string — set after complete, otherwise null",
        "invoiceUrl": "url — payment link sent to customer",
        "createdAt": "datetime (ISO 8601)",
        "updatedAt": "datetime (ISO 8601)"
      }
    },
    "sendInvoice": {
      "draftOrderInvoice": "string"
    },
    "getMany": {
      "draftOrders": "array of draftOrder objects (same fields as above)",
      "count": "number (integer)"
    },
    "delete": {
      "success": "boolean"
    }
  },
  "fieldEnums": {
    "getManyStatus": ["'' (any)", "open", "invoice_sent", "completed"]
