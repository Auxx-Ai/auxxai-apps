        "updateNote": "Updated via workflow",
        "updateTags": "vip,support",
        "updateEmail": "",
        "fieldModes": {
          "updateNote": true,
          "updateTags": true
        },
        "_connectedSourceHandleIds": ["source"],
        "_connectedTargetHandleIds": ["target"]
      },
      "width": 244,
