{
  "$schema": "Shopify App — Draft Order Resource: Node data examples for all operations",
  "$notes": [
    "fieldModes convention (source: isVariableMode = fieldModes[field] !== true):",
    "  true  = constant/literal mode — value is used as-is",
    "  false = variable mode — {{nodeId.field}} references are resolved",
    "  absent = variable mode (same as false)",
    "createLineItems is required. Use variantId for catalog items, or title+price for custom items.",
    "Either createCustomerId or createEmail must be provided for create.",
    "Output for create/get/update/complete: draftOrder.{ draftOrderId, name, status, email, totalPrice, subtotalPrice, currency, tags, note, lineItems, customer, orderId, invoiceUrl, createdAt, updatedAt }",
    "Output for sendInvoice: draftOrderInvoice (string)",
    "Output for getMany: draftOrders[].{ same fields }, count",
    "Output for delete: success"
  ],
  "examples": [
    {
      "$operation": "draftOrder.create",
      "id": "shopify-draft-order-create-001",
      "type": "standard",
      "position": { "x": 0, "y": 0 },
      "data": {
        "id": "shopify-draft-order-create-001",
        "type": "@shopify:shopify",
        "appSlug": "shopify",
        "blockId": "shopify",
        "title": "Shopify: Create Draft Order",
        "desc": "Create a draft order for an existing customer",
        "resource": "draftOrder",
        "operation": "create",
        "createLineItems": [
          {
            "variantId": "{{variant-node.variant.variantId}}",
            "title": "",
            "quantity": 1,
            "price": 0
          }
        ],
        "createCustomerId": "{{customer-node.customers[0].customerId}}",
        "createEmail": "",
        "createNote": "Created via support workflow",
        "createTags": "support,draft",
        "createTaxExempt": false,
        "createUseCustomerDefaultAddress": true,
        "createShippingFirstName": "",
        "createShippingLastName": "",
        "createShippingAddress1": "",
        "createShippingAddress2": "",
        "createShippingCity": "",
        "createShippingProvince": "",
        "createShippingCountry": "",
        "createShippingZip": "",
        "createShippingPhone": "",
        "fieldModes": {
          "createNote": true,
          "createTags": true
        },
        "_connectedSourceHandleIds": ["source"],
        "_connectedTargetHandleIds": ["target"]
      },
      "width": 244,
      "height": 100
    },
    {
      "$operation": "draftOrder.sendInvoice",
      "id": "shopify-draft-order-invoice-001",
      "type": "standard",
      "position": { "x": 0, "y": 0 },
      "data": {
        "id": "shopify-draft-order-invoice-001",
        "type": "@shopify:shopify",
        "appSlug": "shopify",
        "blockId": "shopify",
        "title": "Shopify: Send Draft Invoice",
        "desc": "Email the invoice to the customer",
        "resource": "draftOrder",
        "operation": "sendInvoice",
        "sendInvoiceDraftOrderId": "{{draft-order-node.draftOrder.draftOrderId}}",
        "sendInvoiceTo": "{{customer-node.customers[0].email}}",
        "sendInvoiceSubject": "Your invoice from My Store",
        "sendInvoiceCustomMessage": "Please review your order and complete payment.",
        "sendInvoiceBcc": "",
        "fieldModes": {
          "sendInvoiceSubject": true,
          "sendInvoiceCustomMessage": true
        },
        "_connectedSourceHandleIds": ["source"],
        "_connectedTargetHandleIds": ["target"]
      },
      "width": 244,
      "height": 100
    },
    {
