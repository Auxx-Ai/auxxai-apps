        "type": "@shopify:shopify",
        "appSlug": "shopify",
        "blockId": "shopify",
        "title": "Shopify: Create Product",
        "desc": "Create a new product in Shopify",
        "resource": "product",
        "operation": "create",
        "createTitle": "Classic T-Shirt",
