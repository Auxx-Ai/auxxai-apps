  "outputs": {
    "create_get_update": {
      "product": {
        "productId": "string — Shopify numeric ID",
        "title": "string",
        "bodyHtml": "string — HTML description",
        "vendor": "string",
        "productType": "string",
        "handle": "string — URL-friendly slug",
        "tags": "string — comma-separated",
        "status": "string — e.g. 'active', 'draft', 'archived'",
        "variants": "string (JSON array)",
        "images": "string (JSON array)",
        "createdAt": "datetime (ISO 8601)",
        "updatedAt": "datetime (ISO 8601)"
      }
    },
    "getMany": {
      "products": "array of product objects (same fields as above)",
