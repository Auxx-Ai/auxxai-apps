{
  "$schema": "Shopify App — Product Resource: Node data examples for all operations",
  "$notes": [
    "fieldModes convention (source: isVariableMode = fieldModes[field] !== true):",
    "  true  = constant/literal mode — value is used as-is",
    "  false = variable mode — {{nodeId.field}} references are resolved",
    "  absent = variable mode (same as false)",
    "NOTE: product.get uses 'getProductId' and 'getProductFields' (NOT 'getFields')",
    "NOTE: product.getMany uses 'getProductMany*' prefix for all fields",
    "Output for create/get/update: product.{ productId, title, bodyHtml, vendor, productType, handle, tags, status, variants, images, createdAt, updatedAt }",
    "Output for getMany: products[].{ same fields }, count",
    "Output for delete: success"
  ],
  "examples": [
